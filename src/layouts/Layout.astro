---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Nakama - Fiestas de la Magdalena 2026",
  description = "Haz match con los platos de Nakama Fusion en las Fiestas de la Magdalena 2026. Desliza, enamorate y ven a probarlos a Castellon."
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f5f7f5" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,600;1,400&family=Oswald:wght@400;500;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div class="app">
      <slot />
    </div>

    <style is:global>
      @import '../styles/global.css';

      .app {
        max-width: 430px;
        margin: 0 auto;
        min-height: 100dvh;
        position: relative;
        background: var(--color-bg);
      }

      @media (min-width: 431px) {
        body {
          background: #e8ece9;
        }
        .app {
          box-shadow: 0 0 40px rgba(0, 0, 0, 0.06);
          border-left: 1px solid #dde3de;
          border-right: 1px solid #dde3de;
        }
      }
    </style>
  </body>
</html>
